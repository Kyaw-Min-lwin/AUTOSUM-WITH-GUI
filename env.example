# ============================================================================
# AutoSim — Sovereign Robotics Framework :: Environment configuration
# ----------------------------------------------------------------------------
# 1. Copy this file to ".env" in the project root:
#        cp .env.example .env        (macOS / Linux)
#        copy .env.example .env      (Windows)
# 2. Fill in your real keys below.
# 3. ".env" is git-ignored, so your secrets are never committed.
# ============================================================================

# ---- REQUIRED -------------------------------------------------------------
# Groq powers the real-time agent reasoning (model: openai/gpt-oss-120b).
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ---- OPTIONAL -------------------------------------------------------------
# Only needed if you switch llm_client.py to the GeminiClient instead of Groq.
# Get a key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
